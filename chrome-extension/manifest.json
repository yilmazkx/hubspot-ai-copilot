{
  "manifest_version": 3,
  "name": "HubSpot AI Copilot",
  "description": "AI-powered CRM assistant for HubSpot — powered by Claude",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://app.hubspot.com/*", "https://app-eu1.hubspot.com/*"],
  "content_scripts": [
    {
      "matches": [
        "https://app.hubspot.com/*",
        "https://app-eu1.hubspot.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-copilot": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Toggle AI Copilot panel"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon48.png",
    "default_title": "Toggle AI Copilot"
  }
}
